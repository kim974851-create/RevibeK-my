<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ssafy.revibek.model.dao.SongDao">

    <!-- ResultMap — DB 컬럼 ↔ DTO 필드 매핑 -->
    <resultMap id="SongResultMap" type="com.ssafy.revibek.model.dto.SongDto">
        <id     property="id"              column="id"/>
        <result property="title"           column="title"/>
        <result property="artist"          column="artist"/>
        <result property="genre"           column="genre"/>
        <result property="era"             column="era"/>
        <result property="type"            column="type"/>
        <result property="youtubeUrl"      column="youtube_url"/>
        <result property="youtubeId"       column="youtube_id"/>
        <result property="viewCount"       column="view_count"/>
        <result property="likeCount"       column="like_count"/>
        <result property="trendScore"      column="trend_score"/>
        <result property="score"           column="score"/>
        <result property="scoreUpdatedAt"  column="score_updated_at"/>
        <result property="releasedAt"      column="released_at"/>
        <result property="createdAt"       column="created_at"/>
    </resultMap>

    <!-- 노래 등록 -->
    <insert id="insertSong" parameterType="com.ssafy.revibek.model.dto.SongDto">
        INSERT INTO songs (
            id, title, artist, genre, era, type,
            youtube_url, youtube_id,
            view_count, like_count,
            trend_score, score,
            released_at, created_at
        ) VALUES (
            UUID(), #{title}, #{artist}, #{genre}, #{era}, #{type},
            #{youtubeUrl}, #{youtubeId},
            #{viewCount}, #{likeCount},
            #{trendScore}, #{score},
            #{releasedAt}, NOW()
        )
    </insert>

    <!-- 전체 조회 -->
    <select id="selectAllSongs" resultMap="SongResultMap">
        SELECT *
        FROM songs
        ORDER BY created_at DESC
    </select>

    <!-- ID로 단건 조회 -->
    <select id="selectSongById" parameterType="String" resultMap="SongResultMap">
        SELECT *
        FROM songs
        WHERE id = #{id}
    </select>

    <!-- 제목으로 검색 -->
    <select id="selectSongByTitle" parameterType="String" resultMap="SongResultMap">
        SELECT *
        FROM songs
        WHERE title LIKE CONCAT('%', #{title}, '%')
        ORDER BY score DESC
    </select>

    <!-- 장르별 조회 -->
    <select id="selectSongsByGenre" parameterType="String" resultMap="SongResultMap">
        SELECT *
        FROM songs
        WHERE genre = #{genre}
        ORDER BY score DESC
    </select>

    <!-- 점수 기반 추천 TOP 10 -->
    <select id="selectRecommendSongs" resultMap="SongResultMap">
        SELECT *
        FROM songs
        ORDER BY score DESC
        LIMIT 10
    </select>

    <!-- 노래 정보 수정 -->
    <update id="updateSong" parameterType="com.ssafy.revibek.model.dto.SongDto">
        UPDATE songs
        SET
            title           = #{title},
            artist          = #{artist},
            genre           = #{genre},
            era             = #{era},
            type            = #{type},
            youtube_url     = #{youtubeUrl},
            youtube_id      = #{youtubeId},
            view_count      = #{viewCount},
            like_count      = #{likeCount},
            trend_score     = #{trendScore},
            score           = #{score},
            score_updated_at = NOW(),
            released_at     = #{releasedAt}
        WHERE id = #{id}
    </update>

    <!-- 노래 삭제 -->
    <delete id="deleteSong" parameterType="String">
        DELETE FROM songs
        WHERE id = #{id}
    </delete>

</mapper>